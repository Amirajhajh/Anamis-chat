<!-- templates/registration/password_reset_form.html -->


<!DOCTYPE html>
{% load static %}
<html>
<head>
    <title>{% block title %}Messenger{% endblock %}</title>
    <link rel="stylesheet" href="{% static 'css/accounts.css' %}">

</head>
<body>
    <div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body">
                    <h3 class="text-center mb-4">فراموشی رمز عبور</h3>
                    <p class="text-center text-muted">
                        آدرس ایمیل خود را وارد کنید تا لینک بازیابی رمز عبور برای شما ارسال شود.
                    </p>
                    
                    <form method="post">
                        {% csrf_token %}
                        {{ form.as_p }}
                        <button type="submit" class="btn btn-primary w-100">ارسال لینک بازیابی</button>
                    </form>
                    
                    <div class="text-center mt-3">
                        <a href="{% url 'accounts:login' %}">بازگشت به صفحه ورود</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

    </body>
</html>
